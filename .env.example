# ============================================================
# Railway MySQL Environment Variables
# ============================================================
# Railway provides these variables when you add a MySQL plugin:
MYSQLHOST=your_railway_mysql_host
MYSQLUSER=root
MYSQLPASSWORD=your_railway_mysql_password
MYSQLDATABASE=smart_traffic
MYSQLPORT=3306

# ============================================================
# Alternative: Local Development Variables (if using different names)
# ============================================================
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=your_local_password
# DB_NAME=smart_traffic
# DB_PORT=3306

PORT=3000
